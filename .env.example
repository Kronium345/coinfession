# Copy to `.env` for local dev (never commit this file is gitignored for real secrets).

# Clerk — publishable key (safe in client; required for EAS production builds too).
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here

# Backend API root (no trailing slash). Production builds must use your real HTTPS host.
EXPO_PUBLIC_API_BASE_URL=https://your-api.example.com

# Optional (PostHog is currently disabled in the app bundle; set if you re-enable.)
# EXPO_PUBLIC_POSTHOG_API_KEY=
# EXPO_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
